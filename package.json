{
  "name": "ChecKKPlease",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@cloudflare/workers-types": "^4.20260621.1",
      "lucide-react": "^0.546.0",
      "next": "^16.2.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.5",
      "@trpc/server": "^11.16.0",
      "@trpc/client": "^11.16.0",
      "better-auth": "1.6.11",
      "@opennextjs/cloudflare": "^1.17.3",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "alchemy": "^0.91.2"
    }
  },
  "overrides": {
    "mongodb": "~7.2.0"
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "deploy": "turbo -F @ChecKKPlease/infra deploy",
    "destroy": "turbo -F @ChecKKPlease/infra destroy",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@ChecKKPlease/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ChecKKPlease/config": "workspace:*",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "^22.13.14",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
